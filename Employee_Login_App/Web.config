<?xml version="1.0" encoding="utf-8"?>

<configuration>

  <connectionStrings>
    <add name="con"
    connectionString="Data Source=localhost\SQLEXPRESS01;Initial Catalog=EmployeeDB;Integrated Security=True"
    providerName="System.Data.SqlClient"/>
  </connectionStrings>

  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" />
  </system.web>

  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">

      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Web.Infrastructure"
        publicKeyToken="31bf3856ad364e35"
        culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-2.0.0.0"
        newVersion="2.0.0.0"/>
      </dependentAssembly>

    </assemblyBinding>
  </runtime>

</configuration>